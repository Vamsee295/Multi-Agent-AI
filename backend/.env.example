ENV=development

JWT_SECRET_KEY=replace_with_a_long_random_secret

MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=customer_support_ai

# LLM_PROVIDER: mock | openai | gemini | groq
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Intent detection: keyword | llm | hybrid  (hybrid uses LLM when provider != mock)
INTENT_DETECTION_MODE=hybrid

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_STORE_PATH=vectorstore/index
KNOWLEDGE_BASE_DIR=knowledge_base
RETRIEVAL_SCORE_THRESHOLD=0.0

ALLOWED_ORIGINS=http://localhost:3000
